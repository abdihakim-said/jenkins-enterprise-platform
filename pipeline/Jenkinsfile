#!/usr/bin/env groovy

/**
 * Jenkins Pipeline for Epic 2: Golden Image Creation
 * Story 2.4: DevSecOps pipeline for building and deploying Jenkins Golden AMI
 * 
 * This pipeline implements a complete DevSecOps workflow for:
 * - Building Golden AMI with Packer
 * - Security scanning and vulnerability assessment
 * - Infrastructure deployment with Terraform
 * - Compliance validation
 * - Automated testing and validation
 */

pipeline {
    agent {
        label 'jenkins-master'
    }
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['staging', 'production', 'dev'],
            description: 'Target environment for deployment'
        )
        booleanParam(
            name: 'BUILD_AMI',
            defaultValue: true,
            description: 'Build new Golden AMI with Packer'
        )
        booleanParam(
            name: 'DEPLOY_INFRASTRUCTURE',
            defaultValue: true,
            description: 'Deploy infrastructure with Terraform'
        )
        booleanParam(
            name: 'RUN_SECURITY_SCAN',
            defaultValue: true,
            description: 'Run security vulnerability scanning'
        )
        booleanParam(
            name: 'RUN_COMPLIANCE_CHECK',
            defaultValue: true,
            description: 'Run compliance validation checks'
        )
        string(
            name: 'NOTIFICATION_EMAIL',
            defaultValue: 'devops@company.com',
            description: 'Email for build notifications'
        )
    }
    
    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        PROJECT_NAME = 'jenkins-enterprise-platform'
        EPIC_NAME = 'Epic-2-Golden-Image'
        
        // Tool versions
        TERRAFORM_VERSION = '1.5.7'
        PACKER_VERSION = '1.9.4'
        ANSIBLE_VERSION = '2.15.0'
        
        // Security scanning
        TRIVY_VERSION = 'latest'
        VULNERABILITY_SEVERITY = 'HIGH'
        
        // Build configuration
        BUILD_TIMEOUT = '60'
        PARALLEL_BUILDS = '1'
        
        // Compliance framework
        COMPLIANCE_FRAMEWORK = 'CIS'
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 2, unit: 'HOURS')
        timestamps()
        ansiColor('xterm')
        skipDefaultCheckout(false)
    }
    
    stages {
        stage('🚀 Initialize Pipeline') {
            steps {
                script {
                    echo "🎯 Starting Epic 2: Golden Image Pipeline"
                    echo "📋 Environment: ${params.ENVIRONMENT}"
                    echo "🏗️ Build AMI: ${params.BUILD_AMI}"
                    echo "🚀 Deploy Infrastructure: ${params.DEPLOY_INFRASTRUCTURE}"
                    echo "🔒 Security Scan: ${params.RUN_SECURITY_SCAN}"
                    echo "✅ Compliance Check: ${params.RUN_COMPLIANCE_CHECK}"
                    
                    // Set build description
                    currentBuild.description = "Epic 2 - ${params.ENVIRONMENT} - AMI: ${params.BUILD_AMI}"
                    
                    // Create workspace directories
                    sh '''
                        mkdir -p logs artifacts reports
                        echo "Pipeline started at $(date)" > logs/pipeline.log
                    '''
                }
            }
        }
        
        stage('🔍 Pre-flight Checks') {
            parallel {
                stage('Validate Tools') {
                    steps {
                        script {
                            echo "🛠️ Validating required tools..."
                            sh '''
                                # Check tool versions
                                echo "=== Tool Versions ===" | tee -a logs/pipeline.log
                                terraform version | tee -a logs/pipeline.log
                                packer version | tee -a logs/pipeline.log
                                ansible --version | tee -a logs/pipeline.log
                                aws --version | tee -a logs/pipeline.log
                                docker --version | tee -a logs/pipeline.log
                                
                                # Check AWS credentials
                                echo "=== AWS Identity ===" | tee -a logs/pipeline.log
                                aws sts get-caller-identity | tee -a logs/pipeline.log
                            '''
                        }
                    }
                }
                
                stage('Validate Configuration') {
                    steps {
                        script {
                            echo "📋 Validating configuration files..."
                            sh '''
                                # Validate Packer template
                                cd packer
                                packer validate jenkins-golden-ami.json
                                
                                # Validate Terraform configuration
                                cd ../terraform
                                terraform fmt -check=true -diff=true
                                terraform validate
                                
                                # Validate Ansible playbooks
                                cd ../ansible
                                ansible-playbook --syntax-check roles/jenkins-master/tasks/main.yml
                            '''
                        }
                    }
                }
                
                stage('Security Pre-check') {
                    when {
                        expression { params.RUN_SECURITY_SCAN }
                    }
                    steps {
                        script {
                            echo "🔒 Running security pre-checks..."
                            sh '''
                                # Check for secrets in code
                                echo "=== Secret Scanning ===" | tee -a logs/pipeline.log
                                git secrets --scan || echo "No secrets found"
                                
                                # Validate security configurations
                                echo "=== Security Configuration Validation ===" | tee -a logs/pipeline.log
                                cd security
                                ./validate-security-config.sh || echo "Security validation completed"
                            '''
                        }
                    }
                }
            }
        }
        
        stage('🏗️ Build Golden AMI') {
            when {
                expression { params.BUILD_AMI }
            }
            steps {
                script {
                    echo "🏗️ Building Jenkins Golden AMI with Packer..."
                    
                    // Create Packer variables
                    def packerVars = [
                        aws_region: env.AWS_DEFAULT_REGION,
                        environment: params.ENVIRONMENT,
                        project_name: env.PROJECT_NAME,
                        java_version: "17",
                        jenkins_version: "2.516.1",
                        build_timestamp: new Date().format("yyyyMMdd-HHmmss")
                    ]
                    
                    writeJSON file: 'packer/build-vars.json', json: packerVars
                    
                    sh '''
                        cd packer
                        echo "=== Starting Packer Build ===" | tee -a ../logs/pipeline.log
                        
                        # Build AMI with timeout
                        timeout ${BUILD_TIMEOUT}m packer build \
                            -var-file=build-vars.json \
                            -machine-readable \
                            jenkins-golden-ami.json | tee ../logs/packer-build.log
                        
                        # Extract AMI ID from build output
                        AMI_ID=$(grep 'artifact,0,id' ../logs/packer-build.log | cut -d, -f6 | cut -d: -f2)
                        echo "Built AMI ID: $AMI_ID" | tee -a ../logs/pipeline.log
                        echo "$AMI_ID" > ../artifacts/ami-id.txt
                    '''
                    
                    // Archive build artifacts
                    archiveArtifacts artifacts: 'logs/packer-build.log,artifacts/ami-id.txt', fingerprint: true
                }
            }
            post {
                success {
                    echo "✅ Golden AMI build completed successfully"
                }
                failure {
                    echo "❌ Golden AMI build failed"
                    script {
                        // Cleanup failed build resources
                        sh '''
                            echo "Cleaning up failed build resources..." | tee -a logs/pipeline.log
                            # Add cleanup commands here
                        '''
                    }
                }
            }
        }
        
        stage('🔒 Security Scanning') {
            when {
                expression { params.RUN_SECURITY_SCAN && params.BUILD_AMI }
            }
            parallel {
                stage('Vulnerability Scan') {
                    steps {
                        script {
                            echo "🔍 Running vulnerability scan on Golden AMI..."
                            sh '''
                                cd security
                                
                                # Get AMI ID from build
                                if [ -f ../artifacts/ami-id.txt ]; then
                                    AMI_ID=$(cat ../artifacts/ami-id.txt)
                                    export AMI_ID
                                fi
                                
                                # Run vulnerability scanning
                                echo "=== Vulnerability Scanning ===" | tee -a ../logs/pipeline.log
                                ./vulnerability-scan.sh | tee ../logs/vulnerability-scan.log
                                
                                # Generate security report
                                ./generate-security-report.sh > ../reports/security-report.json
                            '''
                        }
                    }
                    post {
                        always {
                            // Publish security scan results
                            publishHTML([
                                allowMissing: false,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'reports',
                                reportFiles: 'security-report.html',
                                reportName: 'Security Scan Report'
                            ])
                        }
                    }
                }
                
                stage('Compliance Check') {
                    when {
                        expression { params.RUN_COMPLIANCE_CHECK }
                    }
                    steps {
                        script {
                            echo "✅ Running compliance validation..."
                            sh '''
                                cd security
                                
                                # Run CIS benchmark checks
                                echo "=== CIS Compliance Check ===" | tee -a ../logs/pipeline.log
                                ./cis-compliance-check.sh | tee ../logs/compliance-check.log
                                
                                # Generate compliance report
                                ./generate-compliance-report.sh > ../reports/compliance-report.json
                            '''
                        }
                    }
                    post {
                        always {
                            // Publish compliance results
                            publishHTML([
                                allowMissing: false,
                                alwaysLinkToLastBuild: true,
                                keepAll: true,
                                reportDir: 'reports',
                                reportFiles: 'compliance-report.html',
                                reportName: 'Compliance Report'
                            ])
                        }
                    }
                }
            }
        }
        
        stage('🚀 Deploy Infrastructure') {
            when {
                expression { params.DEPLOY_INFRASTRUCTURE }
            }
            steps {
                script {
                    echo "🚀 Deploying infrastructure with Terraform..."
                    
                    sh '''
                        cd terraform
                        
                        # Initialize Terraform
                        echo "=== Terraform Initialize ===" | tee -a ../logs/pipeline.log
                        terraform init -upgrade
                        
                        # Create terraform variables
                        cat > terraform.tfvars << EOF
environment = "${ENVIRONMENT}"
project_name = "${PROJECT_NAME}"
aws_region = "${AWS_DEFAULT_REGION}"
build_ami = ${BUILD_AMI}
enable_security_scan = ${RUN_SECURITY_SCAN}
notification_email = "${NOTIFICATION_EMAIL}"
EOF
                        
                        # Plan infrastructure changes
                        echo "=== Terraform Plan ===" | tee -a ../logs/pipeline.log
                        terraform plan -out=tfplan -var-file=terraform.tfvars | tee ../logs/terraform-plan.log
                        
                        # Apply infrastructure changes
                        echo "=== Terraform Apply ===" | tee -a ../logs/pipeline.log
                        terraform apply -auto-approve tfplan | tee ../logs/terraform-apply.log
                        
                        # Generate outputs
                        terraform output -json > ../artifacts/terraform-outputs.json
                    '''
                    
                    // Archive Terraform artifacts
                    archiveArtifacts artifacts: 'logs/terraform-*.log,artifacts/terraform-outputs.json', fingerprint: true
                }
            }
            post {
                success {
                    echo "✅ Infrastructure deployment completed successfully"
                }
                failure {
                    echo "❌ Infrastructure deployment failed"
                    script {
                        // Attempt to show terraform state for debugging
                        sh '''
                            cd terraform
                            echo "=== Terraform State (for debugging) ===" | tee -a ../logs/pipeline.log
                            terraform show | head -50 | tee -a ../logs/pipeline.log
                        '''
                    }
                }
            }
        }
        
        stage('🧪 Validation & Testing') {
            parallel {
                stage('AMI Validation') {
                    when {
                        expression { params.BUILD_AMI }
                    }
                    steps {
                        script {
                            echo "🧪 Validating Golden AMI..."
                            sh '''
                                # Get AMI ID
                                if [ -f artifacts/ami-id.txt ]; then
                                    AMI_ID=$(cat artifacts/ami-id.txt)
                                    
                                    # Validate AMI exists and is available
                                    echo "=== AMI Validation ===" | tee -a logs/pipeline.log
                                    aws ec2 describe-images --image-ids $AMI_ID --query 'Images[0].State' --output text | tee -a logs/pipeline.log
                                    
                                    # Test AMI by launching a test instance
                                    echo "=== AMI Test Launch ===" | tee -a logs/pipeline.log
                                    # Add test instance launch logic here
                                fi
                            '''
                        }
                    }
                }
                
                stage('Infrastructure Testing') {
                    when {
                        expression { params.DEPLOY_INFRASTRUCTURE }
                    }
                    steps {
                        script {
                            echo "🧪 Testing deployed infrastructure..."
                            sh '''
                                # Test EFS connectivity
                                echo "=== Infrastructure Testing ===" | tee -a logs/pipeline.log
                                
                                # Get EFS ID from Terraform outputs
                                if [ -f artifacts/terraform-outputs.json ]; then
                                    EFS_ID=$(jq -r '.efs_id.value' artifacts/terraform-outputs.json)
                                    echo "Testing EFS: $EFS_ID" | tee -a logs/pipeline.log
                                    
                                    # Validate EFS is available
                                    aws efs describe-file-systems --file-system-id $EFS_ID --query 'FileSystems[0].LifeCycleState' --output text | tee -a logs/pipeline.log
                                fi
                            '''
                        }
                    }
                }
            }
        }
        
        stage('📊 Generate Reports') {
            steps {
                script {
                    echo "📊 Generating comprehensive reports..."
                    sh '''
                        # Create comprehensive build report
                        cat > reports/build-summary.json << EOF
{
    "pipeline_run": {
        "build_number": "${BUILD_NUMBER}",
        "build_url": "${BUILD_URL}",
        "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
        "environment": "${ENVIRONMENT}",
        "project": "${PROJECT_NAME}",
        "epic": "${EPIC_NAME}"
    },
    "build_parameters": {
        "build_ami": ${BUILD_AMI},
        "deploy_infrastructure": ${DEPLOY_INFRASTRUCTURE},
        "security_scan": ${RUN_SECURITY_SCAN},
        "compliance_check": ${RUN_COMPLIANCE_CHECK}
    },
    "artifacts": {
        "ami_id": "$(cat artifacts/ami-id.txt 2>/dev/null || echo 'N/A')",
        "terraform_outputs": "artifacts/terraform-outputs.json"
    },
    "reports": {
        "security_scan": "reports/security-report.json",
        "compliance_check": "reports/compliance-report.json"
    }
}
EOF
                        
                        # Generate HTML summary report
                        python3 -c "
import json
import datetime

# Load build summary
with open('reports/build-summary.json', 'r') as f:
    summary = json.load(f)

# Generate HTML report
html = '''
<!DOCTYPE html>
<html>
<head>
    <title>Epic 2: Golden Image Build Report</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { background-color: #f0f0f0; padding: 20px; border-radius: 5px; }
        .section { margin: 20px 0; padding: 15px; border: 1px solid #ddd; border-radius: 5px; }
        .success { background-color: #d4edda; border-color: #c3e6cb; }
        .info { background-color: #d1ecf1; border-color: #bee5eb; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 8px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: #f2f2f2; }
    </style>
</head>
<body>
    <div class='header'>
        <h1>🎯 Epic 2: Golden Image Build Report</h1>
        <p><strong>Build:</strong> #{build_number} | <strong>Environment:</strong> {environment} | <strong>Timestamp:</strong> {timestamp}</p>
    </div>
    
    <div class='section success'>
        <h2>✅ Build Summary</h2>
        <table>
            <tr><th>Parameter</th><th>Value</th></tr>
            <tr><td>Build AMI</td><td>{build_ami}</td></tr>
            <tr><td>Deploy Infrastructure</td><td>{deploy_infrastructure}</td></tr>
            <tr><td>Security Scan</td><td>{security_scan}</td></tr>
            <tr><td>Compliance Check</td><td>{compliance_check}</td></tr>
        </table>
    </div>
    
    <div class='section info'>
        <h2>📦 Artifacts</h2>
        <ul>
            <li><strong>AMI ID:</strong> {ami_id}</li>
            <li><strong>Terraform Outputs:</strong> Available</li>
            <li><strong>Security Report:</strong> Generated</li>
            <li><strong>Compliance Report:</strong> Generated</li>
        </ul>
    </div>
</body>
</html>
'''.format(
    build_number=summary['pipeline_run']['build_number'],
    environment=summary['pipeline_run']['environment'],
    timestamp=summary['pipeline_run']['timestamp'],
    build_ami=summary['build_parameters']['build_ami'],
    deploy_infrastructure=summary['build_parameters']['deploy_infrastructure'],
    security_scan=summary['build_parameters']['security_scan'],
    compliance_check=summary['build_parameters']['compliance_check'],
    ami_id=summary['artifacts']['ami_id']
)

with open('reports/build-report.html', 'w') as f:
    f.write(html)
"
                    '''
                }
            }
            post {
                always {
                    // Archive all reports and artifacts
                    archiveArtifacts artifacts: 'reports/**/*,artifacts/**/*,logs/**/*', fingerprint: true
                    
                    // Publish HTML reports
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports',
                        reportFiles: 'build-report.html',
                        reportName: 'Epic 2 Build Report'
                    ])
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "🏁 Pipeline completed"
                
                // Clean up workspace
                sh '''
                    echo "=== Pipeline Cleanup ===" | tee -a logs/pipeline.log
                    # Add any necessary cleanup commands
                '''
            }
        }
        
        success {
            script {
                echo "✅ Epic 2: Golden Image Pipeline completed successfully!"
                
                // Send success notification
                if (params.NOTIFICATION_EMAIL) {
                    emailext (
                        subject: "✅ Epic 2 Golden Image Build Success - ${params.ENVIRONMENT}",
                        body: """
                        <h2>🎉 Epic 2: Golden Image Build Completed Successfully!</h2>
                        <p><strong>Environment:</strong> ${params.ENVIRONMENT}</p>
                        <p><strong>Build Number:</strong> ${BUILD_NUMBER}</p>
                        <p><strong>Build URL:</strong> <a href="${BUILD_URL}">${BUILD_URL}</a></p>
                        
                        <h3>Build Parameters:</h3>
                        <ul>
                            <li>Build AMI: ${params.BUILD_AMI}</li>
                            <li>Deploy Infrastructure: ${params.DEPLOY_INFRASTRUCTURE}</li>
                            <li>Security Scan: ${params.RUN_SECURITY_SCAN}</li>
                            <li>Compliance Check: ${params.RUN_COMPLIANCE_CHECK}</li>
                        </ul>
                        
                        <p>All reports and artifacts are available in the build artifacts.</p>
                        """,
                        to: params.NOTIFICATION_EMAIL,
                        mimeType: 'text/html'
                    )
                }
            }
        }
        
        failure {
            script {
                echo "❌ Epic 2: Golden Image Pipeline failed!"
                
                // Send failure notification
                if (params.NOTIFICATION_EMAIL) {
                    emailext (
                        subject: "❌ Epic 2 Golden Image Build Failed - ${params.ENVIRONMENT}",
                        body: """
                        <h2>🚨 Epic 2: Golden Image Build Failed!</h2>
                        <p><strong>Environment:</strong> ${params.ENVIRONMENT}</p>
                        <p><strong>Build Number:</strong> ${BUILD_NUMBER}</p>
                        <p><strong>Build URL:</strong> <a href="${BUILD_URL}">${BUILD_URL}</a></p>
                        <p><strong>Console Output:</strong> <a href="${BUILD_URL}console">${BUILD_URL}console</a></p>
                        
                        <p>Please check the console output and build logs for details.</p>
                        """,
                        to: params.NOTIFICATION_EMAIL,
                        mimeType: 'text/html'
                    )
                }
            }
        }
        
        unstable {
            script {
                echo "⚠️ Epic 2: Golden Image Pipeline completed with warnings"
            }
        }
    }
}
